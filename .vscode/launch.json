{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run atc-helper Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/vscode/atc-helper"
      ],
      "outFiles": [
        "${workspaceFolder}/vscode/atc-helper/out/**/*.js"
      ]
    }
  ]
}
