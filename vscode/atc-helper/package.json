{
  "name": "atc-helper",
  "displayName": "AtC Helper",
  "description": "AtCoder helper commands for VS Code.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:atc-helper.openContestTerminals"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "atc-helper.openContestTerminals",
        "title": "AtC: Open Contest Terminals"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.3"
  }
}
